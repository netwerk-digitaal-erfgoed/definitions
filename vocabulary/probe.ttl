@prefix probe:   <https://def.nde.nl/probe#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix void:    <http://rdfs.org/ns/void#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<https://def.nde.nl/probe> a owl:Ontology ;
    dcterms:title "NDE Probe vocabulary"@en ;
    rdfs:label "NDE Probe vocabulary"@en ;
    dcterms:description "Terms recording what the dataset knowledge graph observed when probing a dataset and its distributions: which capabilities it detected (such as whether it exposes media), and the source-change fingerprint observed for a distribution."@en ;
    dcterms:publisher <https://netwerkdigitaalerfgoed.nl/> ;
    dcterms:creator <https://netwerkdigitaalerfgoed.nl/> ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    dcterms:created "2026-06-11"^^xsd:date ;
    vann:preferredNamespacePrefix "probe" ;
    vann:preferredNamespaceUri "https://def.nde.nl/probe#" ;
    owl:versionInfo "0.1.0" .

probe:Capability a owl:Class ;
    rdfs:label "Capability"@en ;
    rdfs:comment "A feature that the dataset knowledge graph can detect in a dataset by inspecting its data."@en ;
    rdfs:isDefinedBy <https://def.nde.nl/probe> .

probe:detects a owl:ObjectProperty ;
    rdfs:label "detects"@en ;
    rdfs:comment "Links a dataset, or a void:Subset of one, to a capability observed in it. The statement is emitted only when the capability is present, so its mere presence is the positive signal."@en ;
    rdfs:domain void:Dataset ;
    rdfs:range probe:Capability ;
    rdfs:isDefinedBy <https://def.nde.nl/probe> .

probe:media a probe:Capability , owl:NamedIndividual ;
    rdfs:label "media"@en ;
    rdfs:comment "The dataset exposes media objects, for example images, thumbnails or content URLs."@en ;
    rdfs:isDefinedBy <https://def.nde.nl/probe> .

probe:sourceFingerprint a owl:DatatypeProperty ;
    rdfs:label "source fingerprint"@en ;
    rdfs:comment "An opaque change signal for a distribution’s source, derived from the most recent of its declared dct:modified and its HTTP Last-Modified together with its byte size. Compared only for equality, never parsed or ordered. Recorded both on a reachability observation and on a validity quality measurement so the two share one key: a validity verdict applies only while the fingerprint it was judged against still equals the currently-observed one, which is what lets a since-fixed distribution stop showing as invalid."@en ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://def.nde.nl/probe> .
